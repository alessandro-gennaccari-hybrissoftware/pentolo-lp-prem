# Domain (without www) — used for the SSL certificate and nginx config
DOMAIN=yourdomain.com

# Email for Let's Encrypt expiry notifications
EMAIL=you@example.com

# Set to 1 to use Let's Encrypt staging server (avoids rate limits while testing)
STAGING=0

# init-TODO Copy this file to .env.local for local development:
# cp .env.example .env.local
# Then set BASE_URL to your production domain when deploying
